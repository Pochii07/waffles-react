# Browser-exposed (Vite inlines into bundle). Restrict by HTTP referrer in GCP console
# to https://<your-username>.github.io/* and http://localhost:5173/*.
VITE_GOOGLE_MAPS_EMBED_KEY=

# Place ID for the real shop (not secret — it's a public identifier).
# Find via developers.google.com/maps/documentation/places/web-service/place-id.
# Used by both the build script and the browser map embed.
VITE_GOOGLE_PLACE_ID=

# Server-side, only used by scripts/fetch-reviews.mjs at build time.
# Restrict by API in the GCP console (allow only "Places API (New)").
# NEVER set this with a VITE_ prefix — that would inline it into the public bundle.
GOOGLE_PLACES_API_KEY=
